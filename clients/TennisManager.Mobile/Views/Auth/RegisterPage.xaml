<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TennisManager.Mobile.ViewModels.Auth"
             x:Class="TennisManager.Mobile.Views.Auth.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Registracija"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <Label Text="🎾" FontSize="48" HorizontalOptions="Center" />
            <Label Text="Kreirajte račun" FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="{StaticResource Primary}" />

            <BoxView HeightRequest="1" Color="{StaticResource Secondary}" Margin="0,8" />

            <Label Text="Ime" FontAttributes="Bold" />
            <Entry Placeholder="Vaše ime" Text="{Binding FirstName}" ReturnType="Next" />

            <Label Text="Prezime" FontAttributes="Bold" />
            <Entry Placeholder="Vaše prezime" Text="{Binding LastName}" ReturnType="Next" />

            <Label Text="Email" FontAttributes="Bold" />
            <Entry Placeholder="unesite@email.com" Text="{Binding Email}" Keyboard="Email" ReturnType="Next" />

            <Label Text="Telefon (opcionalno)" FontAttributes="Bold" />
            <Entry Placeholder="+385..." Text="{Binding Phone}" Keyboard="Telephone" ReturnType="Next" />

            <Label Text="Lozinka" FontAttributes="Bold" />
            <Entry Placeholder="Minimalno 6 znakova" Text="{Binding Password}" IsPassword="True"
                   ReturnType="Done" ReturnCommand="{Binding RegisterCommand}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                   HorizontalOptions="Center" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <Button Text="Registriraj se"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Label Text="Već imate račun?" VerticalOptions="Center" />
                <Button Text="Prijavite se"
                        Command="{Binding GoToLoginCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        Padding="0" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
