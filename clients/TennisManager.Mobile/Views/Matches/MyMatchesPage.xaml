<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TennisManager.Mobile.ViewModels.Matches"
             xmlns:models="clr-namespace:TennisManager.Mobile.Models"
             x:Class="TennisManager.Mobile.Views.Matches.MyMatchesPage"
             x:DataType="vm:MyMatchesViewModel"
             Title="Moji mečevi">

    <Grid RowDefinitions="Auto,*">

        <Label Grid.Row="0" Text="{Binding ErrorMessage}" TextColor="Red"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
               Padding="16,8" />

        <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}" HorizontalOptions="Center" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="8">

                <Label Text="Nadolazeći mečevi" FontSize="18" FontAttributes="Bold"
                       Padding="16,12,16,4" />

                <CollectionView ItemsSource="{Binding UpcomingMatches}"
                                EmptyView="Nema nadolazećih mečeva."
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MatchDto">
                            <Border Margin="16,4" Padding="12" StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Type, StringFormat='Tip: {0}'}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Status}"
                                           TextColor="{StaticResource Primary}" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding ScheduledAt, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                           TextColor="{StaticResource Secondary}" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MyMatchesViewModel}}, Path=NavigateToMatchCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Prošli mečevi" FontSize="18" FontAttributes="Bold"
                       Padding="16,12,16,4" />

                <CollectionView ItemsSource="{Binding PastMatches}"
                                EmptyView="Nema prošlih mečeva."
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MatchDto">
                            <Border Margin="16,4" Padding="12" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#F5F5F5">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Type, StringFormat='Tip: {0}'}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Status}"
                                           TextColor="{StaticResource Secondary}" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding ScheduledAt, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                           TextColor="{StaticResource Secondary}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
