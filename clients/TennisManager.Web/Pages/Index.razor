@page "/"

<AuthorizeView>
    <Authorized>
        @{ Navigation.NavigateTo("/dashboard"); }
    </Authorized>
    <NotAuthorized>
        <div class="container py-5">
            <div class="row justify-content-center text-center">
                <div class="col-md-8">
                    <h1 class="display-4 fw-bold text-success">TennisManager 🎾</h1>
                    <p class="lead text-muted mt-3">Upravljajte teniskim klubom, rezervacijama, mečevima i ligama na jednom mjestu.</p>
                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a href="/login" class="btn btn-success btn-lg px-5">Prijava</a>
                        <a href="/register" class="btn btn-outline-success btn-lg px-5">Registracija</a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@inject NavigationManager Navigation
