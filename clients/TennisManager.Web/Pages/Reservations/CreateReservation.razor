@page "/clubs/{ClubId:guid}/reservations/create"
@attribute [Authorize]
@inject ReservationService ReservationService
@inject CourtService CourtService
@inject NavigationManager Navigation

<PageTitle>Nova rezervacija</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h2 class="mb-4">Nova rezervacija</h2>
            <ErrorAlert Message="@_errorMessage" />
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label">Teren</label>
                        <select class="form-select" @bind="_model.CourtId">
                            <option value="">-- odaberite teren --</option>
                            @foreach (var c in _courts)
                            {
                                <option value="@c.Id">@c.Name (@c.Surface)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Datum i početak</label>
                        <input type="datetime-local" class="form-control" @bind="_model.StartTime" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Datum i kraj</label>
                        <input type="datetime-local" class="form-control" @bind="_model.EndTime" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vrsta</label>
                        <select class="form-select" @bind="_model.Type">
                            <option value="training">Trening</option>
                            <option value="match">Meč</option>
                            <option value="other">Ostalo</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Napomena</label>
                        <textarea class="form-control" @bind="_model.Notes" rows="2"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" @onclick="HandleCreate" disabled="@_loading">
                            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            Spremi
                        </button>
                        <a href="/clubs/@ClubId/reservations" class="btn btn-secondary">Odustani</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ClubId { get; set; }
    private CreateReservationRequest _model = new() { StartTime = DateTime.Today.AddHours(9), EndTime = DateTime.Today.AddHours(10), Type = "training" };
    private List<CourtDto> _courts = new();
    private bool _loading;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try { _courts = await CourtService.GetCourtsAsync(ClubId); }
        catch { _errorMessage = "Greška pri učitavanju terena."; }
    }

    private async Task HandleCreate()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            var res = await ReservationService.CreateReservationAsync(ClubId, _model);
            if (res is not null)
                Navigation.NavigateTo($"/clubs/{ClubId}/reservations/{res.Id}");
        }
        catch { _errorMessage = "Greška pri stvaranju rezervacije."; }
        finally { _loading = false; }
    }
}
