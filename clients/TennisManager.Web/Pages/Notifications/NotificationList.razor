@page "/notifications"
@attribute [Authorize]
@inject NotificationService NotificationService

<PageTitle>Notifikacije</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Notifikacije</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick="MarkAll" disabled="@_loading">
            Označi sve kao pročitano
        </button>
    </div>
    @if (_loading) { <LoadingSpinner /> }
    else if (_errorMessage is not null) { <ErrorAlert Message="@_errorMessage" /> }
    else if (_notifications.Count == 0) { <EmptyState Message="Nema notifikacija." /> }
    else
    {
        <div class="list-group">
            @foreach (var n in _notifications)
            {
                <div class="list-group-item @(n.IsRead ? "" : "list-group-item-warning fw-bold")">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">@n.Title</h6>
                            <p class="mb-0 fw-normal">@n.Message</p>
                            <small class="text-muted">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                        <div class="d-flex gap-2 ms-3">
                            @if (!n.IsRead)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => MarkRead(n.Id)">Pročitano</button>
                            }
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(n.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NotificationDto> _notifications = new();
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try { _notifications = await NotificationService.GetNotificationsAsync(); }
        catch { _errorMessage = "Greška pri učitavanju notifikacija."; }
        finally { _loading = false; }
    }

    private async Task MarkRead(Guid id)
    {
        try
        {
            await NotificationService.MarkAsReadAsync(id);
            var n = _notifications.FirstOrDefault(x => x.Id == id);
            if (n is not null) n.IsRead = true;
        }
        catch { _errorMessage = "Greška."; }
    }

    private async Task MarkAll()
    {
        try
        {
            await NotificationService.MarkAllAsReadAsync();
            _notifications.ForEach(n => n.IsRead = true);
        }
        catch { _errorMessage = "Greška."; }
    }

    private async Task Delete(Guid id)
    {
        try
        {
            await NotificationService.DeleteNotificationAsync(id);
            _notifications.RemoveAll(n => n.Id == id);
        }
        catch { _errorMessage = "Greška pri brisanju."; }
    }
}
