@page "/clubs/{ClubId:guid}/courts/create"
@attribute [Authorize]
@inject CourtService CourtService
@inject NavigationManager Navigation

<PageTitle>Novi teren</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4">Dodaj teren</h2>
            <ErrorAlert Message="@_errorMessage" />
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <EditForm Model="@_model" OnValidSubmit="HandleCreate">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">Naziv terena</label>
                            <InputText class="form-control" @bind-Value="_model.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Podloga</label>
                            <InputSelect class="form-select" @bind-Value="_model.Surface">
                                <option value="">-- odaberite --</option>
                                <option value="clay">Zemlja (clay)</option>
                                <option value="hard">Tvrda podloga (hard)</option>
                                <option value="grass">Trava (grass)</option>
                                <option value="carpet">Tepih (carpet)</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Okruženje</label>
                            <InputSelect class="form-select" @bind-Value="_model.Environment">
                                <option value="">-- odaberite --</option>
                                <option value="indoor">Zatvoreni (indoor)</option>
                                <option value="outdoor">Otvoreni (outdoor)</option>
                            </InputSelect>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success" disabled="@_loading">
                                @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                Spremi
                            </button>
                            <a href="/clubs/@ClubId/courts" class="btn btn-secondary">Odustani</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ClubId { get; set; }
    private CreateCourtRequest _model = new();
    private bool _loading;
    private string? _errorMessage;

    private async Task HandleCreate()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            await CourtService.CreateCourtAsync(ClubId, _model);
            Navigation.NavigateTo($"/clubs/{ClubId}/courts");
        }
        catch { _errorMessage = "Greška pri stvaranju terena."; }
        finally { _loading = false; }
    }
}
