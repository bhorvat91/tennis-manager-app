@page "/clubs/{ClubId:guid}/courts/{CourtId:guid}/edit"
@attribute [Authorize]
@inject CourtService CourtService
@inject NavigationManager Navigation

<PageTitle>Uredi teren</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4">Uredi teren</h2>
            @if (_loading) { <LoadingSpinner /> }
            else
            {
                <ErrorAlert Message="@_errorMessage" />
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <EditForm Model="@_model" OnValidSubmit="HandleUpdate">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label">Naziv terena</label>
                                <InputText class="form-control" @bind-Value="_model.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Podloga</label>
                                <InputSelect class="form-select" @bind-Value="_model.Surface">
                                    <option value="clay">Zemlja (clay)</option>
                                    <option value="hard">Tvrda podloga (hard)</option>
                                    <option value="grass">Trava (grass)</option>
                                    <option value="carpet">Tepih (carpet)</option>
                                </InputSelect>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Okruženje</label>
                                <InputSelect class="form-select" @bind-Value="_model.Environment">
                                    <option value="indoor">Zatvoreni (indoor)</option>
                                    <option value="outdoor">Otvoreni (outdoor)</option>
                                </InputSelect>
                            </div>
                            <div class="form-check mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsActive" />
                                <label class="form-check-label">Aktivan</label>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success" disabled="@_saving">
                                    @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    Spremi
                                </button>
                                <a href="/clubs/@ClubId/courts" class="btn btn-secondary">Odustani</a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ClubId { get; set; }
    [Parameter] public Guid CourtId { get; set; }
    private UpdateCourtRequest _model = new();
    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var court = await CourtService.GetCourtAsync(ClubId, CourtId);
            if (court is not null)
                _model = new UpdateCourtRequest { Name = court.Name, Surface = court.Surface, Environment = court.Environment, IsActive = court.IsActive };
        }
        catch { _errorMessage = "Greška pri učitavanju terena."; }
        finally { _loading = false; }
    }

    private async Task HandleUpdate()
    {
        _saving = true;
        _errorMessage = null;
        try
        {
            await CourtService.UpdateCourtAsync(ClubId, CourtId, _model);
            Navigation.NavigateTo($"/clubs/{ClubId}/courts");
        }
        catch { _errorMessage = "Greška pri ažuriranju terena."; }
        finally { _saving = false; }
    }
}
